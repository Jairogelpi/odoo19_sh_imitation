<odoo>
  <data>
    <record id="view_openclaw_ai_agent_list" model="ir.ui.view">
      <field name="name">openclaw.ai.agent.list</field>
      <field name="model">openclaw.ai.agent</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="key"/>
          <field name="active"/>
          <field name="llm_profile_id"/>
          <field name="response_style"/>
        </list>
      </field>
    </record>

    <record id="view_openclaw_ai_agent_form" model="ir.ui.view">
      <field name="name">openclaw.ai.agent.form</field>
      <field name="model">openclaw.ai.agent</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <group>
                <field name="name"/>
                <field name="key"/>
                <field name="active"/>
                <field name="llm_profile_id"/>
                <field name="response_style"/>
                <field name="restrict_to_sources"/>
              </group>
              <group>
                <field name="topic_ids" widget="many2many_tags"/>
                <field name="source_ids" widget="many2many_tags"/>
              </group>
            </group>
            <group>
              <field name="description"/>
              <field name="system_prompt"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record id="action_openclaw_ai_agent" model="ir.actions.act_window">
      <field name="name">AI Agents</field>
      <field name="res_model">openclaw.ai.agent</field>
      <field name="view_mode">list,form</field>
    </record>

    <record id="view_openclaw_ai_topic_list" model="ir.ui.view">
      <field name="name">openclaw.ai.topic.list</field>
      <field name="model">openclaw.ai.topic</field>
      <field name="arch" type="xml">
        <list>
          <field name="sequence"/>
          <field name="name"/>
          <field name="key"/>
          <field name="mode"/>
          <field name="active"/>
        </list>
      </field>
    </record>

    <record id="view_openclaw_ai_topic_form" model="ir.ui.view">
      <field name="name">openclaw.ai.topic.form</field>
      <field name="model">openclaw.ai.topic</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <field name="sequence"/>
              <field name="name"/>
              <field name="key"/>
              <field name="mode"/>
              <field name="active"/>
            </group>
            <group>
              <field name="instructions"/>
            </group>
            <group>
              <field name="tool_binding_ids">
                <list editable="bottom">
                  <field name="sequence"/>
                  <field name="tool_id"/>
                  <field name="required"/>
                </list>
              </field>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record id="action_openclaw_ai_topic" model="ir.actions.act_window">
      <field name="name">AI Topics</field>
      <field name="res_model">openclaw.ai.topic</field>
      <field name="view_mode">list,form</field>
    </record>

    <record id="view_openclaw_ai_default_prompt_list" model="ir.ui.view">
      <field name="name">openclaw.ai.default.prompt.list</field>
      <field name="model">openclaw.ai.default_prompt</field>
      <field name="arch" type="xml">
        <list>
          <field name="sequence"/>
          <field name="name"/>
          <field name="agent_id"/>
          <field name="company_id"/>
          <field name="active"/>
        </list>
      </field>
    </record>

    <record id="view_openclaw_ai_default_prompt_form" model="ir.ui.view">
      <field name="name">openclaw.ai.default.prompt.form</field>
      <field name="model">openclaw.ai.default_prompt</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <group>
                <field name="sequence"/>
                <field name="name"/>
                <field name="active"/>
                <field name="applies_to_all_models"/>
                <field name="agent_id"/>
              </group>
              <group>
                <field name="company_id"/>
                <field name="group_ids" widget="many2many_tags"/>
                <field name="model_ids" widget="many2many_tags"/>
              </group>
            </group>
            <group>
              <field name="instructions"/>
            </group>
            <group>
              <field name="button_ids">
                <list editable="bottom">
                  <field name="sequence"/>
                  <field name="label"/>
                  <field name="prompt_text"/>
                  <field name="icon"/>
                </list>
              </field>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record id="action_openclaw_ai_default_prompt" model="ir.actions.act_window">
      <field name="name">Default Prompts</field>
      <field name="res_model">openclaw.ai.default_prompt</field>
      <field name="view_mode">list,form</field>
    </record>

    <record id="view_openclaw_ai_source_list" model="ir.ui.view">
      <field name="name">openclaw.ai.source.list</field>
      <field name="model">openclaw.ai.source</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="key"/>
          <field name="source_type"/>
          <field name="status"/>
          <field name="active"/>
        </list>
      </field>
    </record>

    <record id="view_openclaw_ai_source_form" model="ir.ui.view">
      <field name="name">openclaw.ai.source.form</field>
      <field name="model">openclaw.ai.source</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <field name="name"/>
              <field name="key"/>
              <field name="source_type"/>
              <field name="status"/>
              <field name="active"/>
            </group>
            <group>
              <field name="uri"/>
              <field name="index_ref"/>
              <field name="last_indexed_at"/>
            </group>
            <group>
              <field name="metadata_json"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record id="action_openclaw_ai_source" model="ir.actions.act_window">
      <field name="name">AI Sources</field>
      <field name="res_model">openclaw.ai.source</field>
      <field name="view_mode">list,form</field>
    </record>

    <record id="view_openclaw_ai_tool_list" model="ir.ui.view">
      <field name="name">openclaw.ai.tool.list</field>
      <field name="model">openclaw.ai.tool</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="key"/>
          <field name="required_policy_action"/>
          <field name="execution_kind"/>
          <field name="risk_level"/>
          <field name="active"/>
        </list>
      </field>
    </record>

    <record id="view_openclaw_ai_tool_form" model="ir.ui.view">
      <field name="name">openclaw.ai.tool.form</field>
      <field name="model">openclaw.ai.tool</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <field name="name"/>
              <field name="key"/>
              <field name="gateway_name"/>
              <field name="required_policy_action"/>
              <field name="execution_kind"/>
              <field name="risk_level"/>
              <field name="schema_key"/>
              <field name="schema_version"/>
              <field name="active"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record id="action_openclaw_ai_tool" model="ir.actions.act_window">
      <field name="name">AI Tools</field>
      <field name="res_model">openclaw.ai.tool</field>
      <field name="view_mode">list,form</field>
    </record>

    <record id="view_openclaw_ai_llm_profile_list" model="ir.ui.view">
      <field name="name">openclaw.ai.llm.profile.list</field>
      <field name="model">openclaw.ai.llm_profile</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="backend"/>
          <field name="model_name"/>
          <field name="fallback_model_name"/>
          <field name="active"/>
        </list>
      </field>
    </record>

    <record id="view_openclaw_ai_llm_profile_form" model="ir.ui.view">
      <field name="name">openclaw.ai.llm.profile.form</field>
      <field name="model">openclaw.ai.llm_profile</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <field name="name"/>
              <field name="backend"/>
              <field name="model_name"/>
              <field name="fallback_model_name"/>
              <field name="temperature"/>
              <field name="max_tokens"/>
              <field name="reasoning_enabled"/>
              <field name="supports_tools"/>
              <field name="supports_structured_output"/>
              <field name="active"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record id="action_openclaw_ai_llm_profile" model="ir.actions.act_window">
      <field name="name">LLM Profiles</field>
      <field name="res_model">openclaw.ai.llm_profile</field>
      <field name="view_mode">list,form</field>
    </record>

    <menuitem
      id="menu_openclaw_ai"
      name="Ask AI"
      parent="openclaw.menu_openclaw_root"
      sequence="25"
      groups="openclaw.group_openclaw_admin"/>
    <menuitem
      id="menu_openclaw_ai_agents"
      name="Agents"
      parent="menu_openclaw_ai"
      action="action_openclaw_ai_agent"
      sequence="10"
      groups="openclaw.group_openclaw_admin"/>
    <menuitem
      id="menu_openclaw_ai_topics"
      name="Topics"
      parent="menu_openclaw_ai"
      action="action_openclaw_ai_topic"
      sequence="20"
      groups="openclaw.group_openclaw_admin"/>
    <menuitem
      id="menu_openclaw_ai_default_prompts"
      name="Default Prompts"
      parent="menu_openclaw_ai"
      action="action_openclaw_ai_default_prompt"
      sequence="30"
      groups="openclaw.group_openclaw_admin"/>
    <menuitem
      id="menu_openclaw_ai_sources"
      name="Sources"
      parent="menu_openclaw_ai"
      action="action_openclaw_ai_source"
      sequence="40"
      groups="openclaw.group_openclaw_admin"/>
    <menuitem
      id="menu_openclaw_ai_tools"
      name="Tools"
      parent="menu_openclaw_ai"
      action="action_openclaw_ai_tool"
      sequence="50"
      groups="openclaw.group_openclaw_admin"/>
    <menuitem
      id="menu_openclaw_ai_llm_profiles"
      name="LLM Profiles"
      parent="menu_openclaw_ai"
      action="action_openclaw_ai_llm_profile"
      sequence="60"
      groups="openclaw.group_openclaw_admin"/>
  </data>
</odoo>
