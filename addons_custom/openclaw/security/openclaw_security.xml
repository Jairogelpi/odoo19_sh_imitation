<odoo>
  <data noupdate="1">
    <record id="module_category_openclaw" model="ir.module.category">
      <field name="name">OpenClaw</field>
      <field name="description">Permission profiles for the OpenClaw agent.</field>
      <field name="sequence">35</field>
    </record>

    <record id="privilege_openclaw" model="res.groups.privilege">
      <field name="name">OpenClaw</field>
      <field name="sequence">35</field>
      <field name="category_id" ref="openclaw.module_category_openclaw"/>
    </record>

    <record id="group_openclaw_user" model="res.groups">
      <field name="name">OpenClaw User</field>
      <field name="sequence">10</field>
      <field name="privilege_id" ref="openclaw.privilege_openclaw"/>
    </record>

    <record id="group_openclaw_operator" model="res.groups">
      <field name="name">OpenClaw Operator</field>
      <field name="sequence">20</field>
      <field name="privilege_id" ref="openclaw.privilege_openclaw"/>
      <field name="implied_ids" eval="[(4, ref('openclaw.group_openclaw_user'))]"/>
    </record>

    <record id="group_openclaw_admin" model="res.groups">
      <field name="name">OpenClaw Admin</field>
      <field name="sequence">30</field>
      <field name="privilege_id" ref="openclaw.privilege_openclaw"/>
      <field name="implied_ids" eval="[(4, ref('openclaw.group_openclaw_operator'))]"/>
    </record>

    <record id="base.group_system" model="res.groups">
      <field name="implied_ids" eval="[(4, ref('openclaw.group_openclaw_admin'))]"/>
    </record>

    <record id="rule_openclaw_request_user_own" model="ir.rule">
      <field name="name">OpenClaw requests: own records</field>
      <field name="model_id" ref="model_openclaw_request"/>
      <field name="domain_force">[('requested_by', '=', user.id)]</field>
      <field name="groups" eval="[(4, ref('openclaw.group_openclaw_user'))]"/>
      <field name="perm_read" eval="True"/>
      <field name="perm_write" eval="True"/>
      <field name="perm_create" eval="True"/>
      <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_openclaw_request_operator_all" model="ir.rule">
      <field name="name">OpenClaw requests: operator all records</field>
      <field name="model_id" ref="model_openclaw_request"/>
      <field name="domain_force">[(1, '=', 1)]</field>
      <field name="groups" eval="[(4, ref('openclaw.group_openclaw_operator'))]"/>
      <field name="perm_read" eval="True"/>
      <field name="perm_write" eval="True"/>
      <field name="perm_create" eval="True"/>
      <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_openclaw_request_admin_all" model="ir.rule">
      <field name="name">OpenClaw requests: admin all records</field>
      <field name="model_id" ref="model_openclaw_request"/>
      <field name="domain_force">[(1, '=', 1)]</field>
      <field name="groups" eval="[(4, ref('openclaw.group_openclaw_admin'))]"/>
      <field name="perm_read" eval="True"/>
      <field name="perm_write" eval="True"/>
      <field name="perm_create" eval="True"/>
      <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_openclaw_chat_session_user_own" model="ir.rule">
      <field name="name">OpenClaw chat sessions: own records</field>
      <field name="model_id" ref="model_openclaw_chat_session"/>
      <field name="domain_force">[('user_id', '=', user.id)]</field>
      <field name="groups" eval="[(4, ref('base.group_user'))]"/>
      <field name="perm_read" eval="True"/>
      <field name="perm_write" eval="True"/>
      <field name="perm_create" eval="True"/>
      <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_openclaw_chat_session_admin_all" model="ir.rule">
      <field name="name">OpenClaw chat sessions: admin all records</field>
      <field name="model_id" ref="model_openclaw_chat_session"/>
      <field name="domain_force">[(1, '=', 1)]</field>
      <field name="groups" eval="[(4, ref('openclaw.group_openclaw_admin'))]"/>
      <field name="perm_read" eval="True"/>
      <field name="perm_write" eval="True"/>
      <field name="perm_create" eval="True"/>
      <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_openclaw_chat_message_user_own" model="ir.rule">
      <field name="name">OpenClaw chat messages: own session records</field>
      <field name="model_id" ref="model_openclaw_chat_message"/>
      <field name="domain_force">[('session_id.user_id', '=', user.id)]</field>
      <field name="groups" eval="[(4, ref('base.group_user'))]"/>
      <field name="perm_read" eval="True"/>
      <field name="perm_write" eval="True"/>
      <field name="perm_create" eval="True"/>
      <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_openclaw_chat_message_admin_all" model="ir.rule">
      <field name="name">OpenClaw chat messages: admin all records</field>
      <field name="model_id" ref="model_openclaw_chat_message"/>
      <field name="domain_force">[(1, '=', 1)]</field>
      <field name="groups" eval="[(4, ref('openclaw.group_openclaw_admin'))]"/>
      <field name="perm_read" eval="True"/>
      <field name="perm_write" eval="True"/>
      <field name="perm_create" eval="True"/>
      <field name="perm_unlink" eval="False"/>
    </record>
  </data>
</odoo>
