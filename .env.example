POSTGRES_DB=postgres
POSTGRES_USER=odoo
POSTGRES_PASSWORD=change_me
ODOO_ADMIN_PASSWORD=change_me
PGBACKREST_STANZA=odoo
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change_me

# Optional CI/CD image overrides
# POSTGRES_IMAGE=ghcr.io/<owner>/odoo19-db:<sha>
# PGBACKREST_IMAGE=ghcr.io/<owner>/odoo19-pgbackrest:<sha>
# ODOO_IMAGE=ghcr.io/<owner>/odoo19-odoo:<sha>

# Optional offsite backup settings
OFFSITE_LOCAL_ARCHIVE_DIR=/srv/odoo/backups/offsite
OFFSITE_S3_BUCKET=odoo-backups
OFFSITE_S3_PATH_PREFIX=project/prod
OFFSITE_S3_ENDPOINT=https://s3.example.com
OFFSITE_S3_REGION=eu-west-1
OFFSITE_S3_ACCESS_KEY_ID=change_me
OFFSITE_S3_SECRET_ACCESS_KEY=change_me
OFFSITE_S3_PROVIDER=Other
OFFSITE_S3_FORCE_PATH_STYLE=true
OFFSITE_RCLONE_IMAGE=rclone/rclone:latest

# Optional admin/knowledge layer
PUID=1000
PGID=1000
TZ=Etc/UTC
OBSIDIAN_CUSTOM_USER=obsidian
OBSIDIAN_PASSWORD=change_me

# Lobby (homepage) — comma-separated hostnames allowed to serve the dashboard
HOMEPAGE_ALLOWED_HOSTS=localhost:8081,127.0.0.1:8081

# Control plane (FastAPI UI for pgBackRest, GitHub, docs)
# STACK_ENV identifies the host this control-plane runs on (dev|staging|prod).
# Only `dev` executes local restores; staging/prod render SSH recipes instead.
STACK_ENV=dev
GITHUB_REPO=<owner>/<repo>
# Create a fine-grained PAT with `repo:read` + `actions:read`. NEVER commit it.
GITHUB_TOKEN=
# Docker container names used by `docker exec` for restore/status calls.
PGBACKREST_CONTAINER=odoo19-pgbackrest-1
ODOO_CONTAINER=odoo19-odoo-1
DB_CONTAINER=odoo19-db-1

# OpenClaw external MCP connectors (recommended for server deployments)
# Use full HTTP(S) endpoints that expose MCP JSON-RPC on /mcp.
# If left empty with compose.admin.yaml, control-plane defaults to in-repo services:
# - http://obsidian-mcp:8090/mcp
# - http://memory-mcp:8091/mcp
# - http://context7-mcp:8092/mcp
OPENCLAW_OBSIDIAN_MCP_URL=
OPENCLAW_OBSIDIAN_MCP_TOKEN=change_me_obsidian_mcp_token
OPENCLAW_OBSIDIAN_MCP_TIMEOUT_SECONDS=30

OPENCLAW_MEMORY_MCP_URL=
OPENCLAW_MEMORY_MCP_TOKEN=change_me_memory_mcp_token
OPENCLAW_MEMORY_MCP_TIMEOUT_SECONDS=30

OPENCLAW_CONTEXT7_MCP_URL=
OPENCLAW_CONTEXT7_MCP_TOKEN=change_me_context7_mcp_token
OPENCLAW_CONTEXT7_MCP_TIMEOUT_SECONDS=30
OPENCLAW_CONTEXT7_RESOLVE_TOOL_NAME=resolve-library-id
OPENCLAW_CONTEXT7_QUERY_TOOL_NAME=query-docs

# CIF lookup MCP (Spanish company enrichment by CIF)
OPENCLAW_CIF_LOOKUP_MCP_URL=
OPENCLAW_CIF_LOOKUP_MCP_TOKEN=change_me_cif_lookup_mcp_token
OPENCLAW_CIF_LOOKUP_MCP_TIMEOUT_SECONDS=30
# Optional enrichment for phone/website via Google Maps Places API (leave empty to disable)
GOOGLE_MAPS_API_KEY=

# Code Server (IDE web) — password to access the browser IDE
CODE_SERVER_PASSWORD=change_me

# Grafana (monitoring dashboards)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me
