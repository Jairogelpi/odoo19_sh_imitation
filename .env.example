POSTGRES_DB=postgres
POSTGRES_USER=odoo
POSTGRES_PASSWORD=change_me
ODOO_ADMIN_PASSWORD=change_me
PGBACKREST_STANZA=odoo
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change_me

# Optional CI/CD image overrides
# POSTGRES_IMAGE=ghcr.io/<owner>/odoo19-db:<sha>
# PGBACKREST_IMAGE=ghcr.io/<owner>/odoo19-pgbackrest:<sha>
# ODOO_IMAGE=ghcr.io/<owner>/odoo19-odoo:<sha>

# Optional offsite backup settings
OFFSITE_LOCAL_ARCHIVE_DIR=/srv/odoo/backups/offsite
OFFSITE_S3_BUCKET=odoo-backups
OFFSITE_S3_PATH_PREFIX=project/prod
OFFSITE_S3_ENDPOINT=https://s3.example.com
OFFSITE_S3_REGION=eu-west-1
OFFSITE_S3_ACCESS_KEY_ID=change_me
OFFSITE_S3_SECRET_ACCESS_KEY=change_me
OFFSITE_S3_PROVIDER=Other
OFFSITE_S3_FORCE_PATH_STYLE=true
OFFSITE_RCLONE_IMAGE=rclone/rclone:latest

# Optional admin/knowledge layer
PUID=1000
PGID=1000
TZ=Etc/UTC
OBSIDIAN_CUSTOM_USER=obsidian
OBSIDIAN_PASSWORD=change_me
