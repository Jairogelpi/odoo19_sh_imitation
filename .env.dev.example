POSTGRES_DB=postgres
POSTGRES_USER=odoo
POSTGRES_PASSWORD=change_me
ODOO_ADMIN_PASSWORD=change_me
PGBACKREST_STANZA=odoo
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change_me
SERVER_NAME=_

# Optional CI/CD image overrides
# POSTGRES_IMAGE=ghcr.io/<owner>/odoo19-db:<sha>
# PGBACKREST_IMAGE=ghcr.io/<owner>/odoo19-pgbackrest:<sha>
# ODOO_IMAGE=ghcr.io/<owner>/odoo19-odoo:<sha>

# Optional admin/knowledge layer
PUID=1000
PGID=1000
TZ=Etc/UTC
OBSIDIAN_CUSTOM_USER=obsidian
OBSIDIAN_PASSWORD=change_me

# Lobby (homepage)
HOMEPAGE_ALLOWED_HOSTS=localhost:8081,127.0.0.1:8081

# OpenClaw external MCP connectors (dev)
OPENCLAW_OBSIDIAN_MCP_URL=
OPENCLAW_OBSIDIAN_MCP_TOKEN=change_me_obsidian_mcp_token
OPENCLAW_OBSIDIAN_MCP_TIMEOUT_SECONDS=30

OPENCLAW_MEMORY_MCP_URL=
OPENCLAW_MEMORY_MCP_TOKEN=change_me_memory_mcp_token
OPENCLAW_MEMORY_MCP_TIMEOUT_SECONDS=30

OPENCLAW_CONTEXT7_MCP_URL=
OPENCLAW_CONTEXT7_MCP_TOKEN=change_me_context7_mcp_token
OPENCLAW_CONTEXT7_MCP_TIMEOUT_SECONDS=30
OPENCLAW_CONTEXT7_RESOLVE_TOOL_NAME=resolve-library-id
OPENCLAW_CONTEXT7_QUERY_TOOL_NAME=query-docs

# CIF lookup MCP (Spanish company enrichment by CIF)
OPENCLAW_CIF_LOOKUP_MCP_URL=
OPENCLAW_CIF_LOOKUP_MCP_TOKEN=change_me_cif_lookup_mcp_token
OPENCLAW_CIF_LOOKUP_MCP_TIMEOUT_SECONDS=30
# Optional enrichment for phone/website via Google Maps Places API (leave empty to disable)
GOOGLE_MAPS_API_KEY=

# Code Server (IDE web)
CODE_SERVER_PASSWORD=change_me

# Grafana (monitoring dashboards)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me
